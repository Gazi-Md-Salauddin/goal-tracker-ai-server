# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/goal_tracker_ai?retryWrites=true&w=majority
MONGODB_DB_NAME=goal_tracker_ai

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:5000

# JWT (issued by this server for REST API auth)
JWT_SECRET=replace-with-another-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
